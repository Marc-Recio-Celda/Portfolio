---
/**
 * Página "A closer look" — NEXUS contado desde DOS problemas propios que se
 * resuelven juntos:
 *   (1) no poder recordar todo lo estudiado  → lo arregla NEXUS (la base de
 *       conocimiento).
 *   (2) perder tiempo planificando / reestructurar a mitad → lo arregla la
 *       filosofía de trabajo ligada a NEXUS (planificar antes de construir,
 *       estructura por proyecto, gates).
 * Orientado a un PI de ML. La IA aparece como instrumento dirigido, nunca como
 * dependencia. Sin mención a herramientas de IA concretas. La tesis se usa como
 * ilustración ligera (tendrá su propio apartado), no se explica a fondo.
 *
 * Para añadir/cambiar capturas: subir a `public/how/closer/` y editar el array.
 * Cada figura abre a tamaño completo al clic.
 */
import Base from "../../layouts/Base.astro";
import NexusLayers from "../../components/NexusLayers.astro";
import { withBase } from "../../utils/url";

const DIR = "/how/closer/";

type Fig = { img: string; alt: string; caption: string };

const knowledgeFigs: Fig[] = [
  {
    img: DIR + "nexus-vault.png",
    alt: "The NEXUS vault: numbered domain folders from indices and capture to modelling, visualization and systems.",
    caption: "Eight domains, ~170 linked notes",
  },
  {
    img: "/how/graph.png",
    alt: "Knowledge graph of the vault: hundreds of notes linked into one connected network.",
    caption: "The same notes, linked into one graph",
  },
];

const planFigs: Fig[] = [
  {
    img: DIR + "architecture.png",
    alt: "The architecture file: rules of immutability and auditability, and the first fixed axiom.",
    caption: "Fixed axioms, referable by code",
  },
  {
    img: DIR + "state.png",
    alt: "The state file: a table of gated blocks with their status and workflow notes.",
    caption: "Gated blocks — nothing runs ahead of evidence",
  },
  {
    img: DIR + "decision-log.png",
    alt: "The decision log table: numbered decisions with rationale and date; a superseded one struck through.",
    caption: "Every decision logged, with its rationale",
  },
  {
    img: DIR + "work-guide.png",
    alt: "An auto-generated project cheat-sheet: current block, next action and the gated progression.",
    caption: "Views are generated — the source stays in markdown",
  },
];

const practiceFigs: Fig[] = [
  {
    img: DIR + "project-repo.png",
    alt: "The project repository root with a nexus folder highlighted among the code folders.",
    caption: "A nexus folder, beside the code",
  },
  {
    img: DIR + "project-nexus-contents.png",
    alt: "Inside the project's nexus folder: router, architecture, state, definition, decision log and workflow.",
    caption: "Definition, architecture, state, decision log",
  },
  {
    img: DIR + "router.png",
    alt: "The router note: an up-link to the vault and a map of where each structural file lives.",
    caption: "Each project linked back to the knowledge base",
  },
  {
    img: DIR + "instructions.png",
    alt: "A project's instruction file: identity, domain and the rules it runs under.",
    caption: "The rules a project runs under, in my words",
  },
];
---

<Base
  title="A closer look — how I work"
  description="NEXUS: a knowledge system I built to keep everything I learn and build connected, traceable and reproducible — and a plan-before-you-build way of working to match."
>
  <article class="closer">
    <div class="container closer__wrap">
      <a class="closer__back" href={withBase("/#how-title")}>← Back to how I work</a>

      <header class="closer__header">
        <span class="mono-label">How I work · a closer look</span>
        <h1>NEXUS: knowledge that scales with me</h1>
        <p class="closer__lede">
          Two things slowed me down as a researcher. First, I couldn't hold
          everything I studied in my head. Second, I lost time to planning
          itself — over-thinking it in the abstract, or tearing up half-built
          work to restructure mid-way. NEXUS fixes the first; the way of working
          built around it fixes the second, and the two fit together.
        </p>
      </header>

      <div class="closer__walk">
        <NexusLayers />

        <!-- Problem one — memory -->
        <section class="closer__phase">
          <h2 class="closer__phase-title">A system that remembers for me</h2>
          <p class="closer__phase-intro">
            I stopped relying on memory. Everything I learn — my whole
            data-science master's — lives in NEXUS as linked notes across eight
            domains: one growing graph I can always return to, instead of facts I
            have to keep in my head. Theory stays separate from any single
            project; the vault is knowledge, projects are where it gets applied.
          </p>
          <div class="closer__figs closer__figs--split">
            {knowledgeFigs.map((f) => (
              <figure class="closer__fig">
                <a href={withBase(f.img)} target="_blank" rel="noopener" aria-label={`Open full-size: ${f.caption}`}>
                  <img src={withBase(f.img)} alt={f.alt} loading="lazy" decoding="async" />
                </a>
                <figcaption class="mono-label">{f.caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <!-- Problem two — planning -->
        <section class="closer__phase">
          <h2 class="closer__phase-title">A way of working that plans before it builds</h2>
          <p class="closer__phase-intro">
            My second problem was planning. I'd either over-plan in the abstract
            or, worse, tear up half-built work to restructure it mid-way. NEXUS
            ends that: every project gets its own architecture, axioms and gated
            plan — shaped to it, not forced through a template. I front-load the
            thinking once, in a structure I trust, and I don't start building
            until the shape is clear. Planning became bounded and reusable
            instead of endless — and it has saved me countless headaches.
          </p>
          <p class="closer__phase-intro">
            The rest follows the rules I'd want in any lab: total traceability,
            zero black boxes; every step gated before the next; and the source of
            truth in plain markdown I own, with dashboards generated from it,
            never kept by hand.
          </p>
          <div class="closer__figs closer__figs--split">
            {planFigs.map((f) => (
              <figure class="closer__fig">
                <a href={withBase(f.img)} target="_blank" rel="noopener" aria-label={`Open full-size: ${f.caption}`}>
                  <img src={withBase(f.img)} alt={f.alt} loading="lazy" decoding="async" />
                </a>
                <figcaption class="mono-label">{f.caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <!-- The two together, in practice -->
        <section class="closer__phase">
          <h2 class="closer__phase-title">The two, together, in practice</h2>
          <p class="closer__phase-intro">
            On a real project the two fixes meet. Beside the code, a small
            <code>nexus/</code> folder carries the project's definition,
            architecture, living state and decision log — all linked back to the
            vault, so knowledge and work never drift apart. And when a project
            leans on AI, I keep it on a short leash: where a model would be
            non-deterministic I move the judgment into code, and on borderline
            calls the final verdict stays mine.
          </p>
          <div class="closer__figs closer__figs--split">
            {practiceFigs.map((f) => (
              <figure class="closer__fig">
                <a href={withBase(f.img)} target="_blank" rel="noopener" aria-label={`Open full-size: ${f.caption}`}>
                  <img src={withBase(f.img)} alt={f.alt} loading="lazy" decoding="async" />
                </a>
                <figcaption class="mono-label">{f.caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <!-- Trajectory -->
        <section class="closer__phase">
          <h2 class="closer__phase-title">Built to scale</h2>
          <p class="closer__phase-intro">
            New domains, new projects, the same two fixes — and, in time, a
            consultable knowledge base over the whole vault. The system that
            organized a master's is how I'd approach doctoral research:
            everything connected, everything traceable, scaling with me.
          </p>
        </section>
      </div>

      <p class="closer__outro">
        AI accelerates the work. The architecture, the decisions and the
        verification stay mine.
      </p>
    </div>
  </article>
</Base>

<style>
  .closer {
    padding-block: var(--space-xl) var(--space-2xl);
  }
  .closer__wrap {
    max-width: 54rem;
  }
  .closer__back {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .closer__header {
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-xl);
    border-bottom: var(--border);
  }
  .closer__header h1 {
    margin-top: var(--space-sm);
    font-size: var(--text-2xl);
  }
  .closer__lede {
    margin-top: var(--space-md);
    font-size: var(--text-md);
    color: var(--muted);
  }

  .closer__walk {
    display: grid;
    gap: var(--space-2xl);
  }
  .closer__phase-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-lg);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .closer__phase-intro {
    max-width: var(--measure);
    margin-bottom: var(--space-md);
    font-size: var(--text-md);
  }
  .closer__phase-intro:last-of-type {
    margin-bottom: var(--space-lg);
  }
  .closer__phase-intro code {
    background: var(--paper-2);
    padding: 0.05em 0.35em;
    border-radius: var(--radius);
  }

  .closer__figs {
    display: grid;
    gap: var(--space-lg);
  }
  @media (min-width: 40rem) {
    .closer__figs--split {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .closer__fig {
    margin: 0;
  }
  .closer__fig a {
    display: block;
    border: var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--paper-2);
    transition: border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .closer__fig a:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    box-shadow: 0 6px 24px rgb(0 0 0 / 0.08);
  }
  .closer__fig img {
    width: 100%;
    height: auto;
  }
  .closer__fig figcaption {
    margin-top: var(--space-2xs);
  }

  .closer__outro {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: var(--border);
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: var(--weight-medium);
  }
</style>
