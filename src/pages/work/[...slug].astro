---
/**
 * Páginas de detalle de la collection `work`.
 * Una ruta por entrada (no-draft). Renderiza el markdown con estilos prose.
 */
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { withBase } from "../../utils/url";

export async function getStaticPaths() {
  const entries = await getCollection("work", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.summary}>
  <article class="detail">
    <div class="container detail__wrap">
      <a class="detail__back" href={withBase("/#worknav-title")}>← Back to work</a>

      <header class="detail__header">
        <div class="detail__meta">
          <span class="mono-label">{entry.data.kind}</span>
          {entry.data.status && <span class="detail__status">{entry.data.status}</span>}
        </div>
        <h1>{entry.data.title}</h1>
        <p class="detail__summary">{entry.data.summary}</p>
      </header>

      {entry.data.thumb && (
        <figure class="detail__figure">
          <img src={withBase(entry.data.thumb)} alt={entry.data.thumbAlt ?? ""} />
        </figure>
      )}

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .detail {
    padding-block: var(--space-xl) var(--space-2xl);
  }
  .detail__wrap {
    max-width: 46rem;
  }
  .detail__back {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .detail__status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    border-radius: 999px;
    padding: 0.1em 0.6em;
  }
  .detail__header {
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
    border-bottom: var(--border);
  }
  .detail__summary {
    margin-top: var(--space-sm);
    font-size: var(--text-md);
    color: var(--muted);
  }

  .detail__figure {
    margin: 0 0 var(--space-xl);
  }
  .detail__figure img {
    width: 100%;
    height: auto;
    border: var(--border);
    border-radius: var(--radius-lg);
    background: var(--paper-2);
  }

  /* Prose — estilos del markdown renderizado */
  .prose :global(img) {
    width: 100%;
    height: auto;
    margin-block: var(--space-md);
    border: var(--border);
    border-radius: var(--radius);
    background: var(--paper-2);
  }
  .prose :global(h2) {
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }
  .prose :global(h3) {
    font-size: var(--text-lg);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xs);
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-md);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.25em;
  }
  .prose :global(li) {
    margin-bottom: var(--space-2xs);
  }
  .prose :global(li::marker) {
    color: var(--accent);
  }
  .prose :global(strong) {
    font-weight: var(--weight-semibold);
  }
  .prose :global(blockquote) {
    margin: var(--space-lg) 0;
    padding-left: var(--space-md);
    border-left: 3px solid var(--accent);
    color: var(--muted);
  }
  .prose :global(code) {
    background: var(--paper-2);
    padding: 0.1em 0.4em;
    border-radius: var(--radius);
  }
</style>
