---
/**
 * ScatterViridis — firma visual del sitio.
 * Scatter de embedding (estilo UMAP) generado de forma DETERMINISTA en build,
 * coloreado con la rampa viridis. SVG estático; una única revelación suave al
 * cargar (deshabilitada bajo prefers-reduced-motion vía tokens.css).
 * Es un guiño al colormap estándar del campo, no decoración gratuita.
 */

// Rampa viridis (mismos stops que tokens.css).
const VIRIDIS = ["#440154", "#414487", "#2a788e", "#22a884", "#7ad151", "#fde725"];

// RNG determinista (mulberry32) → el embedding es idéntico en cada build.
function mulberry32(seed: number) {
  return function () {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20240608);

// Box–Muller para ruido gaussiano.
function gauss() {
  const u = 1 - rand();
  const v = rand();
  return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
}

// Clusters tipo embedding, desplazados a la derecha para dejar limpia la
// columna de texto del hero. Centro (0..100), dispersión y stop de color base.
const clusters = [
  { x: 62, y: 30, s: 8, c: 1, n: 38 },
  { x: 74, y: 26, s: 6, c: 0, n: 26 },
  { x: 80, y: 54, s: 10, c: 3, n: 48 },
  { x: 66, y: 68, s: 8, c: 4, n: 40 },
  { x: 90, y: 44, s: 6, c: 5, n: 24 },
  { x: 84, y: 72, s: 6, c: 2, n: 22 },
];

type Pt = { x: number; y: number; r: number; fill: string; o: number };
const points: Pt[] = [];
for (const cl of clusters) {
  for (let i = 0; i < cl.n; i++) {
    const x = cl.x + gauss() * cl.s;
    const y = cl.y + gauss() * cl.s;
    if (x < 1 || x > 99 || y < 1 || y > 99) continue;
    // Variación de color entre stops adyacentes para dar textura.
    const jitter = rand() < 0.28 ? (rand() < 0.5 ? -1 : 1) : 0;
    const idx = Math.min(VIRIDIS.length - 1, Math.max(0, cl.c + jitter));
    points.push({
      x: +x.toFixed(2),
      y: +y.toFixed(2),
      r: +(0.7 + rand() * 0.9).toFixed(2),
      fill: VIRIDIS[idx],
      o: +(0.45 + rand() * 0.4).toFixed(2),
    });
  }
}
---

<svg
  class="scatter"
  viewBox="0 0 100 100"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  focusable="false"
>
  {points.map((p) => <circle cx={p.x} cy={p.y} r={p.r} fill={p.fill} opacity={p.o} />)}
</svg>

<style>
  .scatter {
    width: 100%;
    height: 100%;
    /* Confina el bloom a la derecha; deja limpia la columna de texto. */
    -webkit-mask-image: radial-gradient(
      85% 78% at 84% 46%,
      #000 18%,
      transparent 66%
    );
    mask-image: radial-gradient(85% 78% at 84% 46%, #000 18%, transparent 66%);
    animation: scatter-in 900ms var(--ease) both;
  }

  @keyframes scatter-in {
    from {
      opacity: 0;
      transform: scale(0.985);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
