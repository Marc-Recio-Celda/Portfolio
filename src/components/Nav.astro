---
/**
 * Nav — barra superior sticky con accesos rápidos a cada sección.
 * Enlaces absolutos (/#id) para que funcionen también desde las páginas de
 * detalle. Sin JS: ancla + scroll-behavior smooth global.
 */
import { SITE } from "../consts";
import { withBase } from "../utils/url";

const links = [
  { label: "Skills", href: "/#skills-title" },
  { label: "How I work", href: "/#how-title" },
  { label: "Projects", href: "/#worknav-title" },
  { label: "Experience", href: "/#experience-title" },
  { label: "Studies", href: "/#studies-title" },
  { label: "Contact", href: "/#contact" },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href={withBase("/")}>{SITE.name}</a>
    <nav class="nav__links" aria-label="Sections">
      {links.map((l) => <a href={withBase(l.href)}>{l.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: var(--border);
  }

  .nav__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xs) var(--space-md);
    padding-block: var(--space-2xs);
    min-height: 3.25rem;
  }

  .nav__brand {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-md);
    color: var(--ink);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
  }

  .nav__brand:hover,
  .nav__brand:focus-visible {
    color: var(--accent-deep);
  }

  .nav__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
  }

  .nav__links a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
  }

  .nav__links a:hover,
  .nav__links a:focus-visible {
    color: var(--accent-deep);
  }
</style>
